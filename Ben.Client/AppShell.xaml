<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Ben.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Ben.Views"
    Title="Ben"
    Shell.NavBarIsVisible="False">

    <!-- Login is the default entry point; DailyHostPage is the main app. -->
    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="login" />

    <ShellContent
        ContentTemplate="{DataTemplate views:DailyHostPage}"
        Route="main" />

</Shell>
