<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Ben.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Ben.Views"
    Title="Ben"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <!-- Login page shown first on every cold launch -->
    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <!-- Main planner page; navigated to after successful auth or skip -->
    <ShellContent
        ContentTemplate="{DataTemplate views:DailyHostPage}"
        Route="DailyHostPage" />

</Shell>
