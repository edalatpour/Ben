<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.ProjectManagementView"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto"
          RowSpacing="10">
        <Entry Grid.Row="0"
               Text="{Binding Source={x:Reference Root}, Path=ProjectName, Mode=TwoWay}"
               Placeholder="Project name"
               TextColor="{StaticResource Ink}" />

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="Add"
                    Clicked="OnAddClicked"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="{StaticResource WritingPaper}"
                    CornerRadius="4" />
            <Button Grid.Column="1"
                    Text="Edit"
                    Clicked="OnEditClicked"
                    BackgroundColor="Transparent"
                    BorderColor="{StaticResource Line}"
                    BorderWidth="1"
                    TextColor="{StaticResource Ink}"
                    CornerRadius="4" />
        </Grid>
    </Grid>
</ContentView>
