<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             x:Class="Ben.Views.TaskDetailsPage"
             Title="Task Details">

    <Grid Style="{StaticResource PaperRootGrid}">

        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="12">

            <!-- Header -->

            <Label Grid.Row="0"
                   Text="Task Details"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Task Details Form -->

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}"/>
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid x:Name="TaskDetailsForm"
                          Grid.Row="1"
                          Grid.Column="1"
                          BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="16"
                          RowSpacing="10"
                          ColumnSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.4*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Entry Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="3"
                               x:Name="TitleEntry"
                               Placeholder=""
                               Style="{StaticResource Handwriting}"/>

                        <Grid x:Name="ParentTaskDateRow"
                              Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              IsVisible="False">
                            <Label x:Name="ParentTaskDateLabel"
                                   Style="{StaticResource Handwriting}"
                                   FontSize="16"
                                   LineBreakMode="WordWrap"
                                   TextColor="{DynamicResource Accent}"/>
                        </Grid>

                        <Label Grid.Row="2"
                               Grid.Column="0"
                               Text="Status"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>
                        <Label Grid.Row="2"
                               Grid.Column="1"
                               Text="Priority"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>
                        <Label Grid.Row="2"
                               Grid.Column="2"
                               Text="Order"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>

                        <Border x:Name="StatusBorderNotStarted"
                                Grid.Row="3"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="NotStarted"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text=""
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Style="{StaticResource Handwriting}"/>
                                <Label Text="Not Started"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Ink}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Grid.RowSpan="3"
                                VerticalOptions="Fill"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Button x:Name="PriorityUpButton"
                                        Text="▲"
                                        Clicked="OnPriorityUp"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{DynamicResource Line}"/>
                                <Label x:Name="PriorityLabel"
                                       Text="A"
                                       Style="{StaticResource Handwriting}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HeightRequest="64"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{DynamicResource Line}"/>
                                <Button x:Name="PriorityDownButton"
                                        Text="▼"
                                        Clicked="OnPriorityDown"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="3"
                                Grid.Column="2"
                                Grid.RowSpan="3"
                                VerticalOptions="Fill"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Button x:Name="OrderDownButton"
                                        Text="▲"
                                        Clicked="OnOrderDown"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{DynamicResource Line}"/>
                                <Label x:Name="OrderLabel"
                                       Text="1"
                                       Style="{StaticResource Handwriting}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HeightRequest="64"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{DynamicResource Line}"/>
                                <Button x:Name="OrderUpButton"
                                        Text="▼"
                                        Clicked="OnOrderUp"
                                        BackgroundColor="Transparent"
                                        TextColor="{DynamicResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="StatusBorderInProgress"
                                Grid.Row="4"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="InProgress"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="•"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Style="{StaticResource Handwriting}"/>
                                <Label Text="In Progress"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Ink}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="StatusBorderCompleted"
                                Grid.Row="5"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Completed"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="✓"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Style="{StaticResource Handwriting}"/>
                                <Label Text="Completed"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Ink}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="StatusBorderForwarded"
                                Grid.Row="6"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46"
                                VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Forwarded"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="➝"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Style="{StaticResource Handwriting}"/>
                                <Label Text="Forward To"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Ink}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Grid Grid.Row="6"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Grid.RowSpan="2"
                              x:Name="ForwardingTargetHost"
                              IsVisible="False"
                              HorizontalOptions="Fill"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="8">
                            <views:DateProjectSelectorView x:Name="ForwardTargetSelector"
                                                           Grid.Row="0"
                                                           HorizontalOptions="Fill"/>
                            <Label Grid.Row="1"
                                   Text="{Binding Source={x:Reference ForwardTargetSelector}, Path=SelectionIndicatorText, x:DataType=views:DateProjectSelectorView}"
                                   TextColor="{DynamicResource Ink}"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>

                        <Border x:Name="StatusBorderDeleted"
                                Grid.Row="7"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{DynamicResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46"
                                VerticalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Deleted"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="✗"
                                       HeightRequest="24"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       Style="{StaticResource Handwriting}"/>
                                <Label Text="Delete"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Ink}"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </ScrollView>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

            </Grid>

            <!-- Action buttons -->

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,16,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="{DynamicResource Ink}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"/>

                <Button Grid.Column="1"
                        x:Name="SaveButton"
                        Text="Save"
                        Clicked="OnSaveClicked"
                        BackgroundColor="{DynamicResource Accent}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
