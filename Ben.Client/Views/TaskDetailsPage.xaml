<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.TaskDetailsPage"
             Title="Task Details">

    <Grid Style="{StaticResource PaperRootGrid}">
        <ScrollView>
            <Grid Padding="16"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">

                <!-- Header -->
                <Label Grid.Row="0"
                       Text="Task Details"
                       Style="{StaticResource SectionTitle}"
                       HorizontalTextAlignment="Center"/>

                <!-- Form -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <BoxView Grid.ColumnSpan="2"
                             HeightRequest="3"
                             BackgroundColor="{StaticResource Ink}"/>
                    <BoxView Grid.RowSpan="2"
                             WidthRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                    <Grid Grid.Row="1"
                          Grid.Column="1"
                          BackgroundColor="{StaticResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8">

                        <!-- Title label -->
                        <Label Grid.Row="0"
                               Text="Title"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>

                        <!-- Title entry -->
                        <Entry x:Name="TitleEntry"
                               Grid.Row="1"
                               Placeholder="Enter task title..."
                               Style="{StaticResource Handwriting}"
                               FontSize="24"
                               BackgroundColor="Transparent"/>

                        <!-- Status label -->
                        <Label Grid.Row="2"
                               Text="Status"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"
                               Margin="0,8,0,0"/>

                        <!-- Status picker -->
                        <Grid Grid.Row="3"
                              ColumnDefinitions="*,*,*,*,*"
                              ColumnSpacing="4"
                              Margin="0,4,0,0">
                            <Border x:Name="StatusBorderNotStarted"
                                    Grid.Column="0"
                                    BackgroundColor="Transparent"
                                    Stroke="{StaticResource Line}"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4">
                                <VerticalStackLayout Spacing="2">
                                    <Image Source="not_started.webp"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Not Started"
                                           FontSize="9"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Ink}"/>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatusSelected"
                                                          CommandParameter="NotStarted"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border x:Name="StatusBorderInProgress"
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    Stroke="{StaticResource Line}"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4">
                                <VerticalStackLayout Spacing="2">
                                    <Image Source="in_progress.webp"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           HorizontalOptions="Center"/>
                                    <Label Text="In Progress"
                                           FontSize="9"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Ink}"/>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatusSelected"
                                                          CommandParameter="InProgress"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border x:Name="StatusBorderCompleted"
                                    Grid.Column="2"
                                    BackgroundColor="Transparent"
                                    Stroke="{StaticResource Line}"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4">
                                <VerticalStackLayout Spacing="2">
                                    <Image Source="completed.webp"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Completed"
                                           FontSize="9"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Ink}"/>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatusSelected"
                                                          CommandParameter="Completed"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border x:Name="StatusBorderForwarded"
                                    Grid.Column="3"
                                    BackgroundColor="Transparent"
                                    Stroke="{StaticResource Line}"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4">
                                <VerticalStackLayout Spacing="2">
                                    <Image Source="forwarded.webp"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Forwarded"
                                           FontSize="9"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Ink}"/>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatusSelected"
                                                          CommandParameter="Forwarded"/>
                                </Border.GestureRecognizers>
                            </Border>
                            <Border x:Name="StatusBorderDeleted"
                                    Grid.Column="4"
                                    BackgroundColor="Transparent"
                                    Stroke="{StaticResource Line}"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4">
                                <VerticalStackLayout Spacing="2">
                                    <Image Source="cancelled.webp"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Deleted"
                                           FontSize="9"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Ink}"/>
                                </VerticalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStatusSelected"
                                                          CommandParameter="Deleted"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>

                        <!-- Priority label -->
                        <Label Grid.Row="4"
                               Text="Priority"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"
                               Margin="0,8,0,0"/>

                        <!-- Priority picker -->
                        <Picker x:Name="PriorityPicker"
                                Grid.Row="5"
                                TextColor="{StaticResource Ink}"
                                Style="{StaticResource Handwriting}"
                                FontSize="24"
                                SelectedIndexChanged="OnPriorityChanged"/>

                        <!-- Order label -->
                        <Label Grid.Row="6"
                               Text="Order"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"
                               Margin="0,8,0,0"/>

                        <!-- Order up/down picker -->
                        <HorizontalStackLayout Grid.Row="7"
                                               Spacing="12"
                                               VerticalOptions="Center">
                            <Button Text="▼"
                                    x:Name="OrderDownButton"
                                    Clicked="OnOrderDown"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Ink}"
                                    BorderColor="{StaticResource Line}"
                                    BorderWidth="1"
                                    CornerRadius="4"
                                    FontSize="20"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0"/>
                            <Label x:Name="OrderLabel"
                                   Text="1"
                                   VerticalOptions="Center"
                                   Style="{StaticResource Handwriting}"
                                   FontSize="24"
                                   TextColor="{StaticResource Ink}"
                                   MinimumWidthRequest="40"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="▲"
                                    x:Name="OrderUpButton"
                                    Clicked="OnOrderUp"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Ink}"
                                    BorderColor="{StaticResource Line}"
                                    BorderWidth="1"
                                    CornerRadius="4"
                                    FontSize="20"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0"/>
                        </HorizontalStackLayout>

                    </Grid>

                    <BoxView Grid.Row="2"
                             Grid.ColumnSpan="2"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>
                </Grid>

                <!-- Action buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{StaticResource Ink}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                    <Button Grid.Column="1"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                </Grid>

            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>
