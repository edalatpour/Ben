<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.TaskDetailsPage"
             Title="Task Details">

    <Grid Style="{StaticResource PaperRootGrid}">

        <ScrollView>
            <Grid Padding="16"
                  HorizontalOptions="Fill"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">

                <Label Grid.Row="0"
                       Text="Task Details"
                       Style="{StaticResource SectionTitle}"
                       HorizontalTextAlignment="Center"/>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <BoxView Grid.ColumnSpan="2"
                             HeightRequest="3"
                             BackgroundColor="{StaticResource Ink}"/>
                    <BoxView Grid.RowSpan="2"
                             WidthRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                    <Grid Grid.Row="1"
                          Grid.Column="1"
                          HorizontalOptions="Fill"
                          BackgroundColor="{StaticResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="12">
                        <Entry Grid.Row="0"
                               x:Name="TitleEntry"
                               Placeholder=""
                               Style="{StaticResource Handwriting}"
                               FontSize="24"
                               TextColor="{StaticResource Ink}"/>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="2.4*,1*,1*"
                              RowDefinitions="Auto,46"
                              ColumnSpacing="16"
                              RowSpacing="10">

                            <VerticalStackLayout Grid.Column="0"
                                                 Grid.RowSpan="2"
                                                 Spacing="6">
                                <Label Text="Status"
                                       Style="{StaticResource SectionTitle}"
                                       HorizontalTextAlignment="Start"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>

                                <Border x:Name="StatusBorderNotStarted"
                                        BackgroundColor="Transparent"
                                        Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        HeightRequest="46">
                                    <VerticalStackLayout Spacing="2">
                                        <Image Source="not_started.webp"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Not Started"
                                               FontSize="9"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Ink}"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusSelected"
                                                              CommandParameter="NotStarted"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <Border x:Name="StatusBorderInProgress"
                                        BackgroundColor="Transparent"
                                        Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        HeightRequest="46">
                                    <VerticalStackLayout Spacing="2">
                                        <Image Source="in_progress.webp"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               HorizontalOptions="Center"/>
                                        <Label Text="In Progress"
                                               FontSize="9"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Ink}"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusSelected"
                                                              CommandParameter="InProgress"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <Border x:Name="StatusBorderCompleted"
                                        BackgroundColor="Transparent"
                                        Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        HeightRequest="46">
                                    <VerticalStackLayout Spacing="2">
                                        <Image Source="completed.webp"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Completed"
                                               FontSize="9"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Ink}"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusSelected"
                                                              CommandParameter="Completed"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <Border x:Name="StatusBorderDeleted"
                                        BackgroundColor="Transparent"
                                        Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        HeightRequest="46">
                                    <VerticalStackLayout Spacing="2">
                                        <Image Source="cancelled.webp"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Deleted"
                                               FontSize="9"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Ink}"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusSelected"
                                                              CommandParameter="Deleted"/>
                                    </Border.GestureRecognizers>
                                </Border>

                                <Border x:Name="StatusBorderForwarded"
                                        BackgroundColor="Transparent"
                                        Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="4"
                                        HeightRequest="46">
                                    <VerticalStackLayout Spacing="2">
                                        <Image Source="forwarded.webp"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               HorizontalOptions="Center"/>
                                        <Label Text="Forwarded"
                                               FontSize="9"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{StaticResource Ink}"/>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStatusSelected"
                                                              CommandParameter="Forwarded"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Grid.Row="0"
                                                 Spacing="8">
                                <Label Text="Priority"
                                       Style="{StaticResource SectionTitle}"
                                       HorizontalTextAlignment="Start"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>

                                <Border Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="0">
                                    <VerticalStackLayout Spacing="0">
                                        <Button x:Name="PriorityUpButton"
                                                Text="▲"
                                                Clicked="OnPriorityUp"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Ink}"
                                                HeightRequest="44"
                                                FontSize="20"
                                                Padding="0"/>
                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="{StaticResource Line}"/>
                                        <Label x:Name="PriorityLabel"
                                               Text="A"
                                               Style="{StaticResource Handwriting}"
                                               FontSize="24"
                                               TextColor="{StaticResource Ink}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               HeightRequest="64"/>
                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="{StaticResource Line}"/>
                                        <Button x:Name="PriorityDownButton"
                                                Text="▼"
                                                Clicked="OnPriorityDown"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Ink}"
                                                HeightRequest="44"
                                                FontSize="20"
                                                Padding="0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2"
                                                 Grid.Row="0"
                                                 Spacing="8">
                                <Label Text="Order"
                                       Style="{StaticResource SectionTitle}"
                                       HorizontalTextAlignment="Start"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>

                                <Border Stroke="{StaticResource Line}"
                                        StrokeShape="RoundRectangle 4"
                                        Padding="0">
                                    <VerticalStackLayout Spacing="0">
                                        <Button x:Name="OrderDownButton"
                                                Text="▲"
                                                Clicked="OnOrderDown"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Ink}"
                                                HeightRequest="44"
                                                FontSize="20"
                                                Padding="0"/>
                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="{StaticResource Line}"/>
                                        <Label x:Name="OrderLabel"
                                               Text="1"
                                               Style="{StaticResource Handwriting}"
                                               FontSize="24"
                                               TextColor="{StaticResource Ink}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               HeightRequest="64"/>
                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="{StaticResource Line}"/>
                                        <Button x:Name="OrderUpButton"
                                                Text="▼"
                                                Clicked="OnOrderUp"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource Ink}"
                                                HeightRequest="44"
                                                FontSize="20"
                                                Padding="0"/>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  x:Name="TaskDatePickerHost"
                                  HorizontalOptions="Fill">
                                <DatePicker x:Name="TaskDatePicker"
                                            Format="d"
                                            TextColor="{StaticResource Ink}"
                                            FontSize="18"
                                            HeightRequest="46"
                                            WidthRequest="{Binding Source={x:Reference TaskDatePickerHost}, Path=Width}"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Center"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <BoxView Grid.Row="2"
                             Grid.ColumnSpan="2"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{StaticResource Ink}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                    <Button Grid.Column="1"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                </Grid>
            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
