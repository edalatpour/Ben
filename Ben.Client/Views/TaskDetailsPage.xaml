<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.TaskDetailsPage"
             Title="Task Details">

    <Grid Style="{StaticResource PaperRootGrid}">

        <ScrollView>
            <Grid Padding="16"
                  HorizontalOptions="Fill"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">

                <!-- Header -->

                <Label Grid.Row="0"
                       Text="Task Details"
                       Style="{StaticResource SectionTitle}"
                       HorizontalTextAlignment="Center"/>

                <!-- Task Details Form -->

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <BoxView Grid.ColumnSpan="2"
                             HeightRequest="3"
                             BackgroundColor="{StaticResource Ink}"/>
                    <BoxView Grid.RowSpan="2"
                             WidthRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                    <Grid x:Name="TaskDetailsForm"
                          Grid.Row="1"
                          Grid.Column="1"
                          BackgroundColor="{StaticResource WritingPaper}"
                          Padding="16"
                          RowSpacing="10"
                          ColumnSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                            <RowDefinition Height="46"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.4*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Entry Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="3"
                               x:Name="TitleEntry"
                               Placeholder=""
                               Style="{StaticResource Handwriting}"
                               FontSize="24"
                               TextColor="{StaticResource Ink}"/>

                        <Label Grid.Row="1"
                               Grid.Column="0"
                               Text="Status"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="Priority"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>
                        <Label Grid.Row="1"
                               Grid.Column="2"
                               Text="Order"
                               Style="{StaticResource SectionTitle}"
                               HorizontalTextAlignment="Start"/>

                        <Border x:Name="StatusBorderNotStarted"
                                Grid.Row="2"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <VerticalStackLayout Spacing="2">
                                <Image Source="not_started.webp"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"/>
                                <Label Text="Not Started"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{StaticResource Ink}"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="NotStarted"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Grid.RowSpan="3"
                                VerticalOptions="Fill"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Button x:Name="PriorityUpButton"
                                        Text="▲"
                                        Clicked="OnPriorityUp"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>
                                <Label x:Name="PriorityLabel"
                                       Text="A"
                                       Style="{StaticResource Handwriting}"
                                       FontSize="24"
                                       TextColor="{StaticResource Ink}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HeightRequest="64"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>
                                <Button x:Name="PriorityDownButton"
                                        Text="▼"
                                        Clicked="OnPriorityDown"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Grid.RowSpan="3"
                                VerticalOptions="Fill"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Button x:Name="OrderDownButton"
                                        Text="▲"
                                        Clicked="OnOrderDown"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>
                                <Label x:Name="OrderLabel"
                                       Text="1"
                                       Style="{StaticResource Handwriting}"
                                       FontSize="24"
                                       TextColor="{StaticResource Ink}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HeightRequest="64"/>
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Line}"/>
                                <Button x:Name="OrderUpButton"
                                        Text="▼"
                                        Clicked="OnOrderUp"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource Ink}"
                                        HeightRequest="44"
                                        FontSize="20"
                                        Padding="0"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="StatusBorderInProgress"
                                Grid.Row="3"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <VerticalStackLayout Spacing="2">
                                <Image Source="in_progress.webp"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"/>
                                <Label Text="In Progress"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{StaticResource Ink}"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="InProgress"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="StatusBorderCompleted"
                                Grid.Row="4"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <VerticalStackLayout Spacing="2">
                                <Image Source="completed.webp"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"/>
                                <Label Text="Completed"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{StaticResource Ink}"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Completed"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="StatusBorderForwarded"
                                Grid.Row="5"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <VerticalStackLayout Spacing="2">
                                <Image Source="forwarded.webp"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"/>
                                <Label Text="Forward To"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{StaticResource Ink}"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Forwarded"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <Grid Grid.Row="5"
                              Grid.Column="1"
                              Grid.ColumnSpan="2"
                              x:Name="ForwardedDatePickerHost"
                              IsVisible="False"
                              HorizontalOptions="Fill">
                            <DatePicker x:Name="ForwardedDatePicker"
                                        Format="d"
                                        DateSelected="OnForwardedDateSelected"
                                        TextColor="{StaticResource Ink}"
                                        FontSize="18"
                                        HeightRequest="46"
                                        WidthRequest="{Binding Source={x:Reference ForwardedDatePickerHost}, Path=Width}"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Center"/>
                        </Grid>

                        <Border x:Name="StatusBorderDeleted"
                                Grid.Row="6"
                                Grid.Column="0"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource Line}"
                                StrokeShape="RoundRectangle 4"
                                Padding="4"
                                HeightRequest="46">
                            <VerticalStackLayout Spacing="2">
                                <Image Source="cancelled.webp"
                                       HeightRequest="24"
                                       WidthRequest="24"
                                       HorizontalOptions="Center"/>
                                <Label Text="Delete"
                                       FontSize="9"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{StaticResource Ink}"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatusSelected"
                                                      CommandParameter="Deleted"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <BoxView Grid.Row="2"
                             Grid.ColumnSpan="2"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                </Grid>

                <!-- Action buttons -->

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{StaticResource Ink}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                    <Button Grid.Column="1"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                </Grid>
            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
