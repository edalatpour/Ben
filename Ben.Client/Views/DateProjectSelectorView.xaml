<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bennie.Views.DateProjectSelectorView"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="10">
        <Label Grid.Row="0"
               Text="Date or Project"
               HorizontalTextAlignment="Start"
               Style="{StaticResource SectionTitle}"/>

        <Grid x:Name="DatePickerContainer"
              Grid.Row="1"
              HorizontalOptions="Fill">
            <DatePicker x:Name="SelectorDatePicker"
                        Format="MM/dd/yyyy"
                        HorizontalOptions="Fill"
                        WidthRequest="{Binding Source={x:Reference DatePickerContainer}, Path=Width}"
                        DateSelected="OnDateSelected"
                        TextColor="{StaticResource Ink}"/>
        </Grid>

        <Border Grid.Row="2"
                Stroke="{StaticResource Line}"
                StrokeThickness="1"
                Padding="8">
            <CollectionView x:Name="ProjectsCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnProjectSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8">
                            <Label Text="{Binding Name}"
                                   TextColor="{StaticResource Ink}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentView>
