<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.DailyHostPage"
             x:Name="HostPage">
  <!-- SafeAreaEdges="None" -->

  <Grid x:Name="RootGrid"
        Style="{DynamicResource PaperRootGrid}"
        RowDefinitions="*,Auto">
    <!-- SafeAreaEdges="None" -->
    <Grid.GestureRecognizers>
      <SwipeGestureRecognizer Direction="Left"
                              Swiped="OnSwipeLeft"/>
      <SwipeGestureRecognizer Direction="Right"
                              Swiped="OnSwipeRight"/>
    </Grid.GestureRecognizers>

    <!-- Landscape: show both pages -->
    <Grid x:Name="LandscapeGrid"
          ColumnDefinitions="*,*"
          IsVisible="False">
      <ContentView x:Name="LandscapeTasksHost"/>
      <ContentView x:Name="LandscapeNotesHost"
                   Grid.Column="1"/>
    </Grid>

    <!-- Portrait: show one page at a time -->
    <Grid x:Name="PortraitGrid"
          IsVisible="True">
      <ContentView x:Name="SinglePageHost"/>
    </Grid>

    <Grid ColumnDefinitions="Auto,*,Auto"
          IsVisible="{Binding Source={x:Reference HostPage}, Path=ShowDesktopArrows}"
          VerticalOptions="Fill"
          HorizontalOptions="Fill"
          InputTransparent="True"
          CascadeInputTransparent="False">
      <ImageButton Grid.Column="0"
                   Source="swipe_right.webp"
                   Clicked="OnPreviousClicked"
                   BackgroundColor="{DynamicResource Ink}"
                   Opacity="0.35"
                   WidthRequest="44"
                   HeightRequest="60"
                   Padding="6"
                   Margin="6,0,0,0"
                   VerticalOptions="Center"
                   HorizontalOptions="Start"/>
      <ImageButton Grid.Column="2"
                   Source="swipe_left.webp"
                   Clicked="OnNextClicked"
                   BackgroundColor="{DynamicResource Ink}"
                   Opacity="0.35"
                   WidthRequest="44"
                   HeightRequest="60"
                   Padding="6"
                   Margin="0,0,6,0"
                   VerticalOptions="Center"
                   HorizontalOptions="End"/>
    </Grid>

    <!-- Status Bar -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,*"
          BackgroundColor="{DynamicResource Paper}"
          Padding="16,-16,16,0"
          HeightRequest="32">

      <Label x:Name="SettingsLabel"
             Grid.Column="0"
             Text="Settings"
             IsVisible="{Binding IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}"
             FontSize="12"
             TextColor="{DynamicResource Link}"
             VerticalOptions="Center"
             HorizontalOptions="Start">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Tapped="OnSettingsClicked"/>
        </Label.GestureRecognizers>
      </Label>

      <Border Grid.Column="0"
              IsVisible="{Binding IsAuthenticated}"
              WidthRequest="32"
              HeightRequest="32"
              StrokeThickness="0"
              VerticalOptions="Center"
              HorizontalOptions="Start">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="16"/>
        </Border.StrokeShape>
        <Border.GestureRecognizers>
          <TapGestureRecognizer Tapped="OnSettingsClicked"/>
        </Border.GestureRecognizers>
        <Image Source="{Binding UserAvatarSource}"
               Aspect="AspectFill"
               WidthRequest="32"
               HeightRequest="32"/>
      </Border>

      <Label Grid.Column="1"
             Text="{Binding SyncStatusText}"
             FontSize="12"
             TextColor="{Binding IsSyncClickable, Converter={StaticResource LinkColorConverter}}"
             TextDecorations="{Binding IsSyncClickable, Converter={StaticResource LinkDecorationConverter}}"
             VerticalOptions="Center"
             HorizontalOptions="End">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Tapped="OnSyncStatusTapped"/>
        </Label.GestureRecognizers>
      </Label>
    </Grid>

  </Grid>

</ContentPage>