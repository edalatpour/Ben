<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.SettingsPage"
             x:Name="RootSettingsPage"
             Title="Settings">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False"/>
    </Shell.BackButtonBehavior>

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="12">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Settings"
                   Style="{DynamicResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}"/>
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="16">

                        <!-- Authentication -->
                        <Grid Grid.Row="0"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              HorizontalOptions="Fill"
                              Padding="4,0,4,4">

                            <Image Grid.Column="0"
                                   Source="microsoft.png"
                                   IsVisible="{Binding AuthViewModel.IsAuthenticated, Converter={StaticResource InvertedBoolConverter}}"
                                   Aspect="AspectFit"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Border Grid.Column="0"
                                    IsVisible="{Binding AuthViewModel.IsAuthenticated}"
                                    WidthRequest="24"
                                    HeightRequest="24"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Image Source="{Binding AuthViewModel.UserAvatarSource}"
                                       Aspect="AspectFill"
                                       WidthRequest="24"
                                       HeightRequest="24"/>
                            </Border>

                            <Label Grid.Column="1"
                                   Text="{Binding AuthViewModel.LoginStatusText}"
                                   FontSize="14"
                                   TextColor="{DynamicResource Link}"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLoginStatusTapped"/>
                                </Label.GestureRecognizers>
                            </Label>

                        </Grid>

                        <!-- Theme Selection -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              Padding="4,0,4,0">
                            <Label Grid.Column="0"
                                   Text="Theme"
                                   FontSize="14"
                                   TextColor="{DynamicResource Ink}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"/>

                            <Picker x:Name="ThemeColorPicker"
                                    Grid.Column="1"
                                    SelectedIndexChanged="OnThemeColorSelected"
                                    ItemsSource="{Binding AvailableThemes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Grid>

                    </Grid>

                </ScrollView>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

            </Grid>

            <!-- Action buttons -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,16,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        BackgroundColor="{DynamicResource Ink}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnCancelClicked"/>
                <Button Grid.Column="1"
                        Text="Save"
                        BackgroundColor="{DynamicResource Accent}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnSaveClicked"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
