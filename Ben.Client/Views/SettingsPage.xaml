<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.SettingsPage"
             Title="Settings">

    <Grid Style="{DynamicResource PaperRootGrid}">

        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="12">

            <!-- Header -->
            <Label Grid.Row="0"
                   Text="Settings"
                   Style="{DynamicResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>

            <!-- Form -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}"/>
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill">

                    <Grid BackgroundColor="{DynamicResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="16">

                        <!-- Theme Selection -->
                        <Label Grid.Row="0"
                               Text="Theme:"
                               Style="{DynamicResource SectionTitle}"
                               FontSize="18"/>

                        <Border Grid.Row="1"
                                Stroke="{DynamicResource Ink}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 4"
                                BackgroundColor="{DynamicResource WritingPaper}"
                                MinimumHeightRequest="72"
                                Padding="12,8">
                            <Picker x:Name="ThemeColorPicker"
                                    Title="Select Theme"
                                    SelectedIndexChanged="OnThemeColorSelected"
                                    ItemsSource="{Binding AvailableThemes}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    BackgroundColor="{DynamicResource WritingPaper}"
                                    TextColor="{DynamicResource Ink}"
                                    TitleColor="{DynamicResource Ink}"
                                    FontSize="18"/>
                        </Border>

                        <!-- Preview of selected color -->
                        <BoxView Grid.Row="2"
                                 x:Name="ColorPreview"
                                 HeightRequest="60"
                                 BackgroundColor="{DynamicResource Ink}"
                                 CornerRadius="4"
                                 Margin="0,8,0,0"/>

                    </Grid>

                </ScrollView>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}"/>

            </Grid>

            <!-- Action buttons -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,16,0,0">

                <Button Grid.Column="0"
                        Text="Cancel"
                        BackgroundColor="{DynamicResource Ink}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnCancelClicked"/>
                <Button Grid.Column="1"
                        Text="Save"
                        BackgroundColor="{DynamicResource Accent}"
                        TextColor="{DynamicResource WritingPaper}"
                        CornerRadius="4"
                        HeightRequest="44"
                        Clicked="OnSaveClicked"/>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
