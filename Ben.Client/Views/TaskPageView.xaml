<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             x:Class="Ben.Views.TaskPageView">

    <Grid Padding="16"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="8">

        <!-- Date Header -->

        <VerticalStackLayout Spacing="0"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnHeaderTapped"/>
            </VerticalStackLayout.GestureRecognizers>
            <Label Text="{Binding HeaderPrimaryText}"
                   Style="{StaticResource DateNumber}"
                   LineBreakMode="TailTruncation"
                   MaxLines="1"
                   HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start"/>
            <Label Text="{Binding HeaderSecondaryText}"
                   IsVisible="{Binding ShowDateHeaderDetails}"
                   Style="{StaticResource DateText}"
                   HorizontalTextAlignment="Start"/>
            <Label Text="{Binding HeaderTertiaryText}"
                   IsVisible="{Binding ShowDateHeaderDetails}"
                   Style="{StaticResource DateText}"
                   HorizontalTextAlignment="Start"/>
        </VerticalStackLayout>

        <!-- Section Titles -->

        <Grid Grid.Row="1"
              ColumnDefinitions="28,42,*"
              ColumnSpacing="10"
              Padding="0,4,0,0">
            <Label Text="▼"
                   Grid.Column="0"
                   Margin="7,0,0,0"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="ABC"
                   Grid.Column="1"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Tasks"
                   Grid.Column="2"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="3"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <BoxView Grid.ColumnSpan="2"
                     HeightRequest="3"
                     BackgroundColor="{DynamicResource Ink}"/>
            <BoxView Grid.RowSpan="2"
                     WidthRequest="1"
                     BackgroundColor="{DynamicResource Ink}"/>

            <Grid Grid.Row="1"
                  Grid.Column="1"
                  BackgroundColor="{DynamicResource WritingPaper}"
                  RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0"
                            Margin="0,0,0,8"
                            BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="0"
                                         BindableLayout.ItemsSource="{Binding CurrentDay.Tasks}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                    <Grid ColumnDefinitions="24,1,38,1,*"
                                          RowDefinitions="Auto"
                                          RowSpacing="0"
                                          ColumnSpacing="8"
                                          Padding="0,0,0,0"
                                          VerticalOptions="Start">
                                        <Grid.GestureRecognizers>
                                            <DragGestureRecognizer DragStarting="OnTaskDragStarting"/>
                                            <DropGestureRecognizer Drop="OnTaskDrop"/>
                                            <TapGestureRecognizer Tapped="OnTaskTapped"/>
                                        </Grid.GestureRecognizers>

                                        <Image Grid.Column="0"
                                               Source="{Binding StatusIcon}"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               Margin="8,3,0,0"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Start"/>

                                        <BoxView Grid.Column="1"
                                                 WidthRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"/>
                                        <Label Grid.Column="2"
                                               Margin="0,3,0,0"
                                               Padding="0"
                                               Text="{Binding PriorityOrder}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Start"
                                               LineHeight="1"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.Column="3"
                                                 WidthRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"/>
                                        <Label Grid.Column="4"
                                               Margin="0,3,0,0"
                                               Padding="0"
                                               Text="{Binding TitleWithForwardedDate}"
                                               LineBreakMode="WordWrap"
                                               HorizontalTextAlignment="Start"
                                               VerticalTextAlignment="Start"
                                               LineHeight="1"
                                               Style="{StaticResource Handwriting}"/>
                                        <BoxView Grid.ColumnSpan="5"
                                                 HeightRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"
                                                 VerticalOptions="End"/>
                                    </Grid>
                                </ContentView>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="1"
                      RowDefinitions="1,Auto"
                      ColumnDefinitions="24,1,34,1,*"
                      ColumnSpacing="8"
                      Padding="0,0,0,0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddTaskTapped"/>
                    </Grid.GestureRecognizers>
                    <BoxView Grid.Row="0"
                             Grid.ColumnSpan="5"
                             HeightRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <Image Grid.Row="1"
                           Grid.Column="0"
                           Source="plus.webp"
                           HeightRequest="24"
                           WidthRequest="24"
                           Margin="8,3,0,0"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <BoxView Grid.Row="1"
                             Grid.Column="1"
                             WidthRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <BoxView Grid.Row="1"
                             Grid.Column="3"
                             WidthRequest="1"
                             BackgroundColor="{DynamicResource Line}"/>
                    <Label Grid.Row="1"
                           Grid.Column="4"
                           Text="Tap to add a new task..."
                           VerticalTextAlignment="Center"
                           Style="{StaticResource Handwriting}"
                           FontAttributes="Italic"
                           TextColor="{DynamicResource Line}"/>
                </Grid>
            </Grid>

            <BoxView Grid.Row="1"
                     Grid.ColumnSpan="2"
                     HeightRequest="1"
                     BackgroundColor="{DynamicResource Ink}"
                     VerticalOptions="End"/>
        </Grid>

    </Grid>

</ContentView>
