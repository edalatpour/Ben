<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ben.Views.NoteDetailsPage"
             Title="Note Details">

    <Grid Style="{StaticResource PaperRootGrid}">

        <ScrollView>
            
            <Grid Padding="16"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">

                <!-- Header -->
                <Label Grid.Row="0"
                       Text="Note Details"
                       Style="{StaticResource SectionTitle}"
                       HorizontalTextAlignment="Center"/>

                <!-- Form -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <BoxView Grid.ColumnSpan="2"
                             HeightRequest="3"
                             BackgroundColor="{StaticResource Ink}"/>
                    <BoxView Grid.RowSpan="2"
                             WidthRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                    <Grid Grid.Row="1"
                          Grid.Column="1"
                          BackgroundColor="{StaticResource WritingPaper}"
                          Padding="16"
                          RowDefinitions="*,Auto"
                          RowSpacing="8">

                        <!-- Note text editor -->
                        <Editor x:Name="NoteEditor"
                                Grid.Row="0"
                                Placeholder="Enter note text..."
                                Style="{StaticResource Handwriting}"
                                FontSize="24"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="160"/>

                    </Grid>

                    <BoxView Grid.Row="2"
                             Grid.ColumnSpan="2"
                             HeightRequest="1"
                             BackgroundColor="{StaticResource Ink}"/>

                </Grid>

                <!-- Action buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,16,0,0">

                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{StaticResource Ink}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>
                    <Button Grid.Column="1"
                            Text="Save"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="{StaticResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44"/>

                </Grid>

            </Grid>

        </ScrollView>

    </Grid>

</ContentPage>
