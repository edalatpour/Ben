<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Ben.Views"
             xmlns:viewModels="clr-namespace:Ben.ViewModels"
             x:Class="Ben.Views.PageNavigationPage"
             x:DataType="viewModels:DateProjectPickerViewModel"
             Title="Open Page">

  <Grid Style="{DynamicResource PaperRootGrid}">

    <Grid Padding="16"
          HorizontalOptions="Fill"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="12">

      <Label Grid.Row="0"
             Text="Page Navigation"
             Style="{StaticResource SectionTitle}"
             HorizontalTextAlignment="Center"/>

      <Border Grid.Row="1"
              Style="{DynamicResource ThemedCard}"
              StrokeThickness="{DynamicResource CardBorderThickness}">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="{DynamicResource ListCardCornerRadius}"/>
        </Border.StrokeShape>

        <ScrollView HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    BackgroundColor="{DynamicResource WritingPaper}">

          <Grid BackgroundColor="{DynamicResource WritingPaper}"
                Padding="16"
                RowDefinitions="Auto,Auto,Auto"
                RowSpacing="12">
            <views:DateProjectSelectorView Grid.Row="0"
                                           x:Name="PageSelector"
                                           Projects="{Binding Projects}"/>

            <views:ProjectManagementView Grid.Row="1"
                                         ProjectName="{Binding ProjectNameInput, Mode=TwoWay}"
                                         AddRequested="OnAddProjectClicked"
                                         EditRequested="OnEditProjectClicked"/>

            <Label Grid.Row="2"
                   Text="{Binding Source={x:Reference PageSelector}, Path=SelectionIndicatorText, x:DataType=views:DateProjectSelectorView}"
                   TextColor="{DynamicResource Ink}"
                   HorizontalTextAlignment="Center"/>
          </Grid>
        </ScrollView>
      </Border>

      <Grid Grid.Row="2"
            ColumnDefinitions="*,*"
            ColumnSpacing="12"
            Margin="0,16,0,0">
        <Button Grid.Column="0"
                Text="Cancel"
                Clicked="OnCancelClicked"
                Style="{DynamicResource SecondaryActionButton}"
                HeightRequest="44"/>
        <Button Grid.Column="1"
                Text="Go"
                Clicked="OnGoToPageClicked"
                Style="{DynamicResource PrimaryActionButton}"
                HeightRequest="44"/>
      </Grid>
    </Grid>
  </Grid>
</ContentPage>