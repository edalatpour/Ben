<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             x:Class="Ben.Views.SearchPage"
             Title="Search Notes">

    <Grid Style="{DynamicResource PaperRootGrid}">
        <Grid Padding="16"
              HorizontalOptions="Fill"
              RowDefinitions="Auto,*,Auto"
              RowSpacing="12">

            <Label Grid.Row="0"
                   Text="Search Notes"
                   Style="{StaticResource SectionTitle}"
                   HorizontalTextAlignment="Center" />

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="1" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <BoxView Grid.ColumnSpan="2"
                         HeightRequest="3"
                         BackgroundColor="{DynamicResource Ink}" />
                <BoxView Grid.RowSpan="3"
                         WidthRequest="1"
                         BackgroundColor="{DynamicResource Ink}" />

                <Grid Grid.Row="1"
                      Grid.Column="1"
                      BackgroundColor="{DynamicResource WritingPaper}">
                    <sfListView:SfListView x:Name="SearchResultsList"
                                           Margin="0"
                                           BackgroundColor="Transparent"
                                           ItemsSource="{Binding SearchResults}"
                                           AutoFitMode="DynamicHeight"
                                           SelectionMode="Single"
                                           SelectedItem="{Binding SelectedResult, Mode=TwoWay}">
                        <sfListView:SfListView.ItemTemplate>
                            <DataTemplate>
                                <ContentView BackgroundColor="{DynamicResource WritingPaper}">
                                    <Grid ColumnDefinitions="72,1,*"
                                          RowDefinitions="Auto"
                                          RowSpacing="0"
                                          ColumnSpacing="8"
                                          Padding="0,0,0,0"
                                          VerticalOptions="Start">
                                        <Label Grid.Column="0"
                                               Text="{Binding DateOrder}"
                                               Margin="0,3,0,0"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Start"
                                               LineHeight="1"
                                               Style="{StaticResource Handwriting}" />
                                        <BoxView Grid.Column="1"
                                                 WidthRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Fill" />
                                        <Label Grid.Column="2"
                                               Margin="0,3,0,0"
                                               LineBreakMode="WordWrap"
                                               HorizontalTextAlignment="Start"
                                               VerticalTextAlignment="Start"
                                               LineHeight="1"
                                               Style="{StaticResource Handwriting}"
                                               FormattedText="{Binding HighlightedText}" />
                                        <BoxView Grid.ColumnSpan="3"
                                                 HeightRequest="1"
                                                 BackgroundColor="{DynamicResource Line}"
                                                 VerticalOptions="End" />
                                    </Grid>
                                </ContentView>
                            </DataTemplate>
                        </sfListView:SfListView.ItemTemplate>
                    </sfListView:SfListView>
                </Grid>

                <BoxView Grid.Row="2"
                         Grid.ColumnSpan="2"
                         HeightRequest="1"
                         BackgroundColor="{DynamicResource Ink}" />
            </Grid>

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="12"
                  Margin="0,16,0,0">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <Entry x:Name="SearchEntry"
                           Grid.Column="0"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           Placeholder="Enter text to find in notes"
                           ReturnType="Search"
                           Completed="OnSearchSubmitted"
                           FontFamily="{DynamicResource UserHandwritingFont}"
                           FontSize="24"
                           TextColor="{DynamicResource UserText}"
                           BackgroundColor="Transparent" />
                    <Button x:Name="SearchActionButton"
                            Grid.Column="1"
                            Text="Search"
                            Clicked="OnSearchClicked"
                            BackgroundColor="{DynamicResource Accent}"
                            TextColor="{DynamicResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44" />
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{DynamicResource Ink}"
                            TextColor="{DynamicResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44" />
                    <Button Grid.Column="1"
                            Text="Go"
                            Clicked="OnGoClicked"
                            BackgroundColor="{DynamicResource Accent}"
                            TextColor="{DynamicResource WritingPaper}"
                            CornerRadius="4"
                            HeightRequest="44" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
