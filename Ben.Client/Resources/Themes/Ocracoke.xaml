<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Ben.Resources.Themes.Ocracoke">

    <!-- Ocracoke Lighthouse — White Minimalist -->

    <Color x:Key="Paper">#FFFFFF</Color>
    <Color x:Key="WritingPaper">#FFFFFF</Color>

    <Color x:Key="Ink">#2B2B2B</Color>
    <Color x:Key="Line">#E6E6E6</Color>

    <Color x:Key="Accent">#5A5A5A</Color>
    <Color x:Key="Link">#555555</Color>

    <Color x:Key="UserText">#000000</Color>

    <Color x:Key="PageBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="CardBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="InkBrush">#2B2B2B</Color>
    <Color x:Key="SecondaryInkBrush">#888888</Color>
    <Color x:Key="GlyphBrush">#2B2B2B</Color>
    <Color x:Key="AccentBrush">#5A5A5A</Color>
    <Color x:Key="SelectionBrush">#805A5A5A</Color>
    <Color x:Key="HighlightBrush">#335A5A5A</Color>
    <Color x:Key="HeaderBackgroundBrush">#FFFFFF</Color>
    <Color x:Key="HeaderForegroundBrush">#2B2B2B</Color>
    <Color x:Key="CheckboxStrokeBrush">#CCCCCC</Color>
    <Color x:Key="CheckboxFillBrush">#2B2B2B</Color>
    <Color x:Key="BorderColor">#CCCCCC</Color>
    <Color x:Key="GridLineColor">#E6E6E6</Color>
    <Color x:Key="DividerColor">#E6E6E6</Color>
    <x:Double x:Key="BorderThickness">1</x:Double>
    <x:Double x:Key="DividerThickness">1</x:Double>
    <x:Double x:Key="CornerRadius">2</x:Double>
    <x:String x:Key="ThemeHeaderFont">Inter-Regular</x:String>
    <x:String x:Key="ThemeDateNumberFont">Inter-Regular</x:String>
    <x:String x:Key="ThemeDateDayFont">Lato-Regular</x:String>

</ResourceDictionary>
